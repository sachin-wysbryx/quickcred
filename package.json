{
  "name": "quickcred",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm db:generate && pnpm --filter web... build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint",
    "db:generate": "pnpm --filter @repo/db exec prisma generate",
    "db:push": "pnpm --filter @repo/db exec prisma db push",
    "reset:data": "npx --yes tsx scripts/resetDatabase.ts",
    "test": "vitest",
    "test:e2e": "playwright test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^28.1.0",
    "next": "16.1.6",
    "playwright": "^1.58.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "vitest": "^4.1.0"
  }
}